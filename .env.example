# ---- Gateway (nosso) ----
SICOOB_TOKEN=troque-por-um-segredo-forte     # header X-Sicoob-Token que o núcleo/retaguarda envia
DRY_RUN=1                                     # 1 = simula (NÃO paga). Só vira 0 quando for pra valer.
CAP_POR_PIX=50                               # teto por Pix (R$)
CAP_DIARIO=500                               # teto por dia (R$)

# ---- Sicoob ----
SICOOB_AMBIENTE=sandbox                       # sandbox | producao
SICOOB_CLIENT_ID=                             # do portal (Meus Aplicativos)
SICOOB_SCOPE=                                 # escopo de pagamento Pix (conferir no app do portal)
SICOOB_TOKEN_URL=https://auth.sicoob.com.br/auth/realms/cooperado/protocol/openid-connect/token

# sandbox: token de teste do Dashboard (sem certificado)
SICOOB_SANDBOX_TOKEN=

# produção: certificado A1 (PFX) em base64 + senha  (base64: `base64 -w0 cert.pfx`)
SICOOB_PFX_BASE64=
SICOOB_PFX_SENHA=

# endpoint EXATO do Pix pagamento — pegar no Swagger da API de Pagamentos no portal
SICOOB_PIX_PAG_URL=
